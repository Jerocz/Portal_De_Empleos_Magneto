# Copia este archivo como ".env" y completa tus credenciales de MySQL
# cp .env.example .env

# Formato: mysql+pymysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=mysql+pymysql://root:TU_CONTRASEÑA@localhost:3306/magneto_db

# Ejemplos según tu herramienta:
#
# XAMPP (sin contraseña en root):
#   DATABASE_URL=mysql+pymysql://root:@localhost:3306/magneto_db
#
# MySQL Workbench / instalación local con contraseña:
#   DATABASE_URL=mysql+pymysql://root:mi_contraseña@localhost:3306/magneto_db
#
# WAMP64:
#   DATABASE_URL=mysql+pymysql://root:@localhost:3306/magneto_db
