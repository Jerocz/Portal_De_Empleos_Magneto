classDiagram
    %% =============================================
    %% CAPA DE ESTRATEGIAS (Patrón Strategy + Composite)
    %% =============================================

    class MatchingStrategy {
        <<abstract>>
        +name() str
        +calculate(user_profile dict, job dict) tuple[float, str]
    }

    class CityMatchStrategy {
        +name() str
        +calculate(user_profile dict, job dict) tuple[float, str]
    }

    class ModalityMatchStrategy {
        +name() str
        +calculate(user_profile dict, job dict) tuple[float, str]
    }

    class SalaryMatchStrategy {
        +name() str
        +calculate(user_profile dict, job dict) tuple[float, str]
    }

    class SkillsMatchStrategy {
        +name() str
        +calculate(user_profile dict, job dict) tuple[float, str]
    }

    class CompositeMatchingStrategy {
        -_strategies list[MatchingStrategy]
        +__init__()
        +calculate(user_profile dict, job dict) tuple[float, str]
    }

    class _normalize {
        <<function>>
        +_normalize(text str) str
    }

    MatchingStrategy <|-- CityMatchStrategy : implements
    MatchingStrategy <|-- ModalityMatchStrategy : implements
    MatchingStrategy <|-- SalaryMatchStrategy : implements
    MatchingStrategy <|-- SkillsMatchStrategy : implements
    CompositeMatchingStrategy o-- MatchingStrategy : composes

    %% =============================================
    %% CAPA DE REPOSITORIOS (Patrón Repository)
    %% =============================================

    class UserRepository {
        -_db Session
        +__init__(db Session)
        +find_by_id(user_id int) dict
        +find_by_email(email str) dict
        +email_exists(email str) bool
        +create(email str, full_name str, password_hash str, role str) dict
        +delete(user_id int) bool
    }

    class JobRepository {
        -_db Session
        +__init__(db Session)
        +find_all(city str, modality str, limit int) list
        +find_by_id(job_id int) dict
        +find_by_employer(user_id int) list
        +create(title str, ...) dict
        +delete(job_id int, owner_id int) bool
        -_parse_skills(job dict) dict
    }

    class ProfileRepository {
        -_db Session
        +__init__(db Session)
        +find_by_user_id(user_id int) dict
        +upsert(user_id int, ...) None
    }

    class MatchRepository {
        -_db Session
        +__init__(db Session)
        +find_by_user(user_id int, limit int) list
        +find_by_user_job_date(user_id int, job_id int, run_date date) dict
        +create(user_id int, job_id int, score float, explanation str, run_date date) None
        +find_notifications(user_id int, min_score float, limit int) list
    }

    class ApplicationRepository {
        -_db Session
        +__init__(db Session)
        +already_applied(job_id int, employee_id int) bool
        +create(job_id int, employee_id int, message str) dict
        +find_by_employee(employee_id int) list
        +find_by_employer(employer_id int) list
        +update_status(application_id int, employer_id int, status str) bool
        +delete(application_id int, employee_id int) bool
    }

    %% =============================================
    %% CAPA DE DTOs Y FACTORY (Patrón Factory)
    %% =============================================

    class UserProfileDTO {
        <<dataclass>>
        +id int
        +email str
        +full_name str
        +location_city str
        +modality str
        +salary_min_cop int
        +salary_max_cop int
        +years_exp int
        +skills list
    }

    class JobDTO {
        <<dataclass>>
        +id int
        +title str
        +company str
        +city str
        +modality str
        +salary_min_cop int
        +salary_max_cop int
        +skills_required list
        +description str
    }

    class MatchResultDTO {
        <<dataclass>>
        +id int
        +job_id int
        +title str
        +company str
        +city str
        +modality str
        +score float
        +explanation str
        +run_date str
        +salary_min_cop int
        +salary_max_cop int
        +skills_required list
    }

    class DTOFactory {
        <<Pure Fabrication>>
        +create_user_profile_dto(user dict, profile dict) UserProfileDTO
        +create_job_dto(job dict) JobDTO
        +create_match_result_dto(match dict) MatchResultDTO
        +user_profile_dto_to_dict(dto UserProfileDTO) dict
        +job_dto_to_dict(dto JobDTO) dict
        +match_dto_to_dict(dto MatchResultDTO) dict
    }

    DTOFactory ..> UserProfileDTO : creates
    DTOFactory ..> JobDTO : creates
    DTOFactory ..> MatchResultDTO : creates

    %% =============================================
    %% CAPA DE SEGURIDAD
    %% =============================================

    class SecurityModule {
        <<module>>
        +SECRET_KEY str
        +ALGORITHM str
        +TOKEN_EXPIRE_HOURS int
        +hash_password(password str) str
        +verify_password(plain str, hashed str) bool
        +create_token(user_id int) str
        +get_current_user(token str, db Session) dict
    }

    %% =============================================
    %% CAPA DE ROUTERS (Controladores FastAPI)
    %% =============================================

    class AuthRouter {
        <<FastAPI Router>>
        +prefix /auth
        +register(data RegisterData, db Session) dict
        +login(data LoginData, db Session) dict
    }

    class ProfileRouter {
        <<FastAPI Router>>
        +prefix /profile
        +get_profile(current_user dict, db Session) dict
        +update_profile(data ProfileUpdate, current_user dict, db Session) dict
        +delete_account(current_user dict, db Session) dict
    }

    class JobsRouter {
        <<FastAPI Router>>
        +prefix /jobs
        +list_jobs(city str, modality str, db Session) list
        +create_job(data JobCreate, current_user dict, db Session) dict
        +my_jobs(current_user dict, db Session) list
        +get_job(job_id int, db Session) dict
        +delete_job(job_id int, current_user dict, db Session) dict
    }

    class MatchingRouter {
        <<FastAPI Router>>
        +prefix /matches
        +run_matching(current_user dict, db Session) dict
        +get_my_matches(current_user dict, db Session) list
    }

    class ApplicationsRouter {
        <<FastAPI Router>>
        +prefix /applications
        +apply_to_job(data ApplyData, current_user dict, db Session) dict
        +my_applications(current_user dict, db Session) list
        +employer_inbox(current_user dict, db Session) list
        +update_status(application_id int, data StatusUpdate, current_user dict, db Session) dict
        +withdraw_application(application_id int, current_user dict, db Session) dict
    }

    class NotificationsRouter {
        <<FastAPI Router>>
        +prefix /notifications
        +SCORE_MINIMO int
        +get_notifications(current_user dict, db Session) dict
    }

    AuthRouter --> UserRepository : uses
    AuthRouter --> SecurityModule : uses
    ProfileRouter --> ProfileRepository : uses
    ProfileRouter --> UserRepository : uses
    ProfileRouter --> DTOFactory : uses
    JobsRouter --> JobRepository : uses
    JobsRouter --> DTOFactory : uses
    MatchingRouter --> CompositeMatchingStrategy : uses
    MatchingRouter --> ProfileRepository : uses
    MatchingRouter --> JobRepository : uses
    MatchingRouter --> MatchRepository : uses
    MatchingRouter --> DTOFactory : uses
    MatchingRouter --> SecurityModule : uses
    ApplicationsRouter --> ApplicationRepository : uses
    NotificationsRouter --> MatchRepository : uses
